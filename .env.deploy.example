# Copy to .env.deploy and fill in. Never commit the filled file.

# Postgres (container-local; not exposed to the internet).
POSTGRES_PASSWORD=change-me

# Qwen cloud — Model Studio, Singapore/international endpoint. The free
# quota (1M tokens per model, 90 days) covers a hackathon comfortably.
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# qwen-plus is the cost/quality sweet spot for extraction; qwen-max is better
# and also free-quota'd, qwen-flash is cheapest.
QWEN_MODEL=qwen-plus
# Embeddings: `qwen` = DashScope text-embedding-v4 (1024-d). `deterministic`
# needs no API at all but scores ~0.19 NDCG lower — see results/history/.
BRAINIAC_EMBEDDER=qwen

# Identity. Until you mint managed keys in the console (/keys), the bootstrap
# admin principal comes from this map. Generate the UUIDs once and keep them.
#   BRAINIAC_TOKENS={"<secret>":{"org":"<uuid>","user":"<uuid>","teams":["<uuid>"]}}
BRAINIAC_TOKENS={"change-me-admin":{"org":"00000000-0000-0000-0000-000000000001","user":"00000000-0000-0000-0000-000000000002","teams":[]}}

# The console talks to the server with this token (must exist in the map
# above, or be a managed key minted later).
BRAINIAC_API_TOKEN=change-me-admin

# Console access gate. REQUIRED in production: the console reads and writes the
# live org knowledge base with the privileged token above, so without a passcode
# it refuses to serve anything but the public pitch ("/") and the fixture-org
# demo ("/demo"). Use a long random string — this is a shared secret for the
# deployment, not a per-user login.
#   openssl rand -base64 32
CONSOLE_PASSCODE=change-me-console

RUST_LOG=info
