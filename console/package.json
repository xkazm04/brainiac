{
  "name": "brainiac-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "cross-env NEXT_DIST_DIR=.next-build next build",
    "start": "cross-env NEXT_DIST_DIR=.next-build next start -p 3100",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev:fresh": "node -e \"fs.rmSync('.next',{recursive:true,force:true})\" && next dev -p 3100",
    "gen:api": "openapi-typescript ../openapi.json -o src/lib/api-schema.d.ts"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
