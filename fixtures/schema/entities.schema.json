{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EntitiesFile",
  "type": "object",
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EntityFx"
      }
    }
  },
  "required": [
    "entities"
  ],
  "$defs": {
    "EntityFx": {
      "type": "object",
      "properties": {
        "aliases": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "team": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "team",
        "name",
        "kind"
      ]
    }
  }
}
