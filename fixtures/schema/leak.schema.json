{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LeakFile",
  "type": "object",
  "properties": {
    "queries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LeakQueryFx"
      }
    }
  },
  "required": [
    "queries"
  ],
  "$defs": {
    "AskingAsFx": {
      "type": "object",
      "properties": {
        "team": {
          "description": "Omitted = a TEAMLESS asker — the observer posture\n(docs/VISIBILITY-TIERS.md §1): org membership, no team memberships,\nso RLS resolves them to org-visible rows only. The linter requires the\nnamed user to actually be teamless, so the fixture cannot claim a\nposture the seeded principal does not have.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "user": {
          "type": "string"
        }
      },
      "required": [
        "user"
      ]
    },
    "LeakQueryFx": {
      "type": "object",
      "properties": {
        "asking_as": {
          "$ref": "#/$defs/AskingAsFx"
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "query": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "query",
        "asking_as",
        "forbidden"
      ]
    }
  }
}
