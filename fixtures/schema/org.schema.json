{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrgFile",
  "type": "object",
  "properties": {
    "org": {
      "type": "string"
    },
    "teams": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TeamFx"
      }
    },
    "users": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/UserFx"
      }
    }
  },
  "required": [
    "org",
    "teams",
    "users"
  ],
  "$defs": {
    "TeamFx": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "UserFx": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "teams": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "email",
        "teams",
        "role"
      ]
    }
  }
}
