{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoriesFile",
  "type": "object",
  "properties": {
    "memories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MemoryFx"
      }
    }
  },
  "required": [
    "memories"
  ],
  "$defs": {
    "MemoryFx": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string"
        },
        "detail_md": {
          "description": "KB-PLAN D3 — the artifact the statement summarizes, when the gold\nmemory has one (composition gold uses these to check that pages render\nstructure instead of paraphrasing it away).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "entities": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "lifecycle": {
          "description": "KB-PLAN D2 — omit for shipped reality (the overwhelming default).",
          "type": "string",
          "default": "shipped"
        },
        "owner": {
          "description": "Required when visibility == private.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RelationFx"
          }
        },
        "source": {
          "description": "Transcript this memory was distilled from.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "status": {
          "type": "string",
          "default": "canonical"
        },
        "superseded_by": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "team": {
          "type": "string"
        },
        "title": {
          "description": "A short label for the archive's row (migration 0023). Optional: the\nhand-authored v1 corpus predates it and falls back to `content`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "valid_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "default": null
        },
        "valid_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "default": null
        },
        "visibility": {
          "type": "string",
          "default": "team"
        }
      },
      "required": [
        "id",
        "team",
        "kind",
        "content"
      ]
    },
    "RelationFx": {
      "type": "object",
      "properties": {
        "dst": {
          "type": "string"
        },
        "rel": {
          "type": "string"
        },
        "src": {
          "type": "string"
        }
      },
      "required": [
        "src",
        "rel",
        "dst"
      ]
    }
  }
}
